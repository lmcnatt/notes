# McNotes environment configuration
# Copy to `.env` and adjust as needed. All values are optional.

# Directory that holds the SQLite database and per-user markdown files.
# In Docker this defaults to /data (a mounted volume). For local dev it
# defaults to ./data in the project root.
# DATA_DIR=/data

# Secret used to sign session JWTs. REQUIRED in production.
# In Docker, if unset, a strong secret is generated and stored in DATA_DIR/.jwt_secret.
# Generate one with: openssl rand -hex 48
# JWT_SECRET=

# HTTP port the server listens on.
# PORT=3010

# Allow public self-registration ("true"/"false"). Default: false.
# The first-ever account is always allowed and becomes the admin, who can then
# toggle this at runtime from Admin Settings.
# ALLOW_REGISTRATION=false

# (Optional) Domain for Caddy reverse proxy. Only used if you uncomment the
# Caddy service in docker-compose.yml.
# Set this to your domain (e.g., notes.example.com).
# Requires your domain's DNS A record to point to this server's IP.
# Caddy will auto-generate HTTPS certificates via Let's Encrypt.
# DOMAIN=notes.example.com
